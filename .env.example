# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Security ───────────────────────────────────
# Passphrase: every message must start with this. Leave empty to disable (not recommended).
BRIDGE_SECRET=

# ── Accounts ───────────────────────────────────
# Trusted iMessage sender IDs (comma-separated, phone numbers and emails)
SENDER_IDS=you@icloud.com,+1234567890

# Default reply-to address
SENDER_ID=you@icloud.com

# ── AI CLI Paths ────────────────────────────────
CLAUDE_PATH=/Users/yourname/.npm-global/bin/claude
GEMINI_PATH=/Users/yourname/.npm-global/bin/gemini
CODEX_PATH=/Users/yourname/.npm-global/bin/codex

# ── Behavior ───────────────────────────────────
# Default model: claude / gemini / codex
DEFAULT_MODEL=gemini

# Task timeout in seconds
TASK_TIMEOUT=300

# Message chunk size (characters)
CHUNK_SIZE=2000

# Conversation memory: keep last N turns per model
MEMORY_TURNS=10

# ── Web Search (Tavily) ─────────────────────────
# Get your free API key at https://tavily.com
TAVILY_API_KEY=

# Progress notification interval (seconds, 0 to disable)
PROGRESS_INTERVAL=20
