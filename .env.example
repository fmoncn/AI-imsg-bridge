# 复制此文件为 .env 并填入你的实际配置
# cp .env.example .env

# ── 安全 ──────────────────────────────────────
# 授权口令：每条指令必须以此开头，留空则关闭验证（不推荐）
BRIDGE_SECRET=your_secret_here

# ── 账号 ──────────────────────────────────────
# 受信任的 iMessage 发件人（逗号分隔，支持手机号和邮箱）
SENDER_IDS=you@me.com,you@gmail.com,+8613800000000

# 默认回复目标账号
SENDER_ID=you@me.com

# ── AI CLI 路径 ────────────────────────────────
CLAUDE_PATH=/Users/yourname/.npm-global/bin/claude
GEMINI_PATH=/Users/yourname/.npm-global/bin/gemini
CODEX_PATH=/Users/yourname/.npm-global/bin/codex

# ── 行为 ──────────────────────────────────────
# 默认模型：claude / gemini / codex
DEFAULT_MODEL=claude

# 任务超时秒数
TASK_TIMEOUT=300

# 消息分块大小（字符数）
CHUNK_SIZE=2000
